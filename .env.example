# agent_body_lab — Environment Variables
# ──────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values in .env
# 3. .env is gitignored — never commit it

# ── Prusa Connect ─────────────────────
PRUSA_API_KEY=your_prusa_connect_api_key_here
PRUSA_PRINTER_ID=your_printer_uuid_here
PRUSA_SERVER_URL=https://connect.prusa3d.com

# ── Pipeline Control ──────────────────
# Set to true to run full loop without dispatching to hardware
DRY_RUN=true
